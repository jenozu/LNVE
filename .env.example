# ============================================================
# LNVE Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Google Maps (required for scraping) ──────────────────────
GOOGLE_MAPS_KEY=your_google_maps_api_key_here

# ── OpenAI (required for market analysis + landing pages) ────
OPENAI_API_KEY=your_openai_api_key_here

# ── Flask ────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string
FLASK_DEBUG=0

# ── Enrichment: Search APIs (need at least ONE) ───────────────
BING_V7_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# ── Enrichment: Optional Verifiers ───────────────────────────
HUNTER_API_KEY=
SNOV_API_KEY=

# ── Proxy (optional, leave blank to use direct connection) ────
PROXIES=
PROXY_FAIL_THRESHOLD=3
PROXY_COOLDOWN=300

# ── Rate Limiting ─────────────────────────────────────────────
RATE_GOOGLE=2
RATE_YELLOWPAGES=1
RATE_BING=2
MIN_DELAY=0.4
MAX_DELAY=1.2
RETRY_MAX=3
LEAD_PAUSE_MIN=1.0
LEAD_PAUSE_MAX=3.0
